generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model account {
  id                Int      @id @default(autoincrement())
  provider          String
  providerAccountId String
  userId            Int
  createdAt         DateTime @default(now())
  user              user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Account_userId_fkey")

  @@unique([provider, providerAccountId], map: "Account_provider_providerAccountId_key")
  @@index([userId], map: "Account_userId_fkey")
}

model achievement {
  id                 Int     @id @default(autoincrement())
  key                String  @unique(map: "Achievement_key_key")
  titleAr            String
  titleEn            String
  descriptionAr      String?
  descriptionEn      String?
  targetCourses      Int?
  targetCertificates Int?
  targetStreakDays   Int?
}

model admin {
  id               Int          @id @default(autoincrement())
  name             String
  email            String       @unique(map: "Admin_email_key")
  passwordHash     String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime
  livesession_created livesession[]
  chatConversationsAsCounterpart chatconversation[]
  chatMessages     chatmessage[]
}

model attendance {
  id            Int                      @id @default(autoincrement())
  teacherId     Int
  courseId      Int
  userId        Int
  sessionType   attendance_sessionType   @default(offline)
  sessionDate   DateTime
  sessionTime   String?
  price         Int?
  paymentStatus attendance_paymentStatus @default(unpaid)
  paidAmount    Int?
  treasuryId    Int?
  paymentMethod String?
  createdAt     DateTime                 @default(now())
  user          user                     @relation(fields: [teacherId], references: [id], onDelete: Cascade, map: "Attendance_teacherId_fkey")

  @@index([teacherId], map: "Attendance_teacherId_fkey")
}

model cartitem {
  id       Int      @id @default(autoincrement())
  userId   Int
  courseId Int
  addedAt  DateTime @default(now())
  course   course   @relation(fields: [courseId], references: [id], onDelete: Cascade, map: "CartItem_courseId_fkey")
  user     user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "CartItem_userId_fkey")

  @@unique([userId, courseId], map: "CartItem_userId_courseId_key")
  @@index([courseId], map: "CartItem_courseId_fkey")
}

model category {
  id             Int        @id @default(autoincrement())
  nameAr         String
  nameEn         String
  slug           String     @unique(map: "Category_slug_key")
  parentId       Int?
  order          Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime
  category       category?  @relation("categoryTocategory", fields: [parentId], references: [id], map: "Category_parentId_fkey")
  other_category category[] @relation("categoryTocategory")
  course         course[]

  @@index([parentId], map: "Category_parentId_fkey")
}

model country {
  id        Int      @id @default(autoincrement())
  nameAr    String
  nameEn    String
  code      String?  @unique(map: "Country_code_key")
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model coupon {
  id            Int                 @id @default(autoincrement())
  code          String              @unique(map: "Coupon_code_key")
  discountType  coupon_discountType @default(percentage)
  discountValue Int
  maxUses       Int?                @default(1)
  usedCount     Int                 @default(0)
  expiresAt     DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime
}

model course {
  id            Int             @id @default(autoincrement())
  slug          String          @unique(map: "Course_slug_key")
  titleAr       String
  titleEn       String
  instructorAr  String
  instructorEn  String
  rating        Float
  students      Int
  price         Int
  originalPrice Int
  category      String
  level         String
  hours         Int
  lessons       Int
  sections      Int
  updatedAt     DateTime
  instructorId  Int?
  isFeatured    Boolean         @default(false)
  status        String          @default("published")
  categoryId    Int?
  coverImageUrl String?
  cartitem      cartitem[]
  categoryRef   category?       @relation(fields: [categoryId], references: [id], map: "Course_categoryId_fkey")
  user          user?           @relation(fields: [instructorId], references: [id], map: "Course_instructorId_fkey")
  coursesection coursesection[]
  enrollment    enrollment[]
  livesession   livesession[]
  payment       payment[]
  wishlistitem  wishlistitem[]

  @@index([categoryId], map: "Course_categoryId_fkey")
  @@index([instructorId], map: "Course_instructorId_fkey")
}

model courselesson {
  id                  Int           @id @default(autoincrement())
  sectionId           Int
  order               Int           @default(0)
  titleAr             String
  titleEn             String
  duration            String?
  videoUrl            String?       // video link (YouTube, etc.)
  videoPath           String?       // uploaded video file path
  examId        Int?
  homeworkId    Int?
  createdAt     DateTime      @default(now())
  coursesection coursesection @relation(fields: [sectionId], references: [id], onDelete: Cascade, map: "CourseLesson_sectionId_fkey")
  exam          exam?         @relation(fields: [examId], references: [id], onDelete: SetNull, map: "CourseLesson_examId_fkey")
  homework      homework?     @relation(fields: [homeworkId], references: [id], onDelete: SetNull, map: "CourseLesson_homeworkId_fkey")
  attachments   lessonattachment[]

  @@index([sectionId], map: "CourseLesson_sectionId_fkey")
  @@index([examId], map: "CourseLesson_examId_fkey")
  @@index([homeworkId], map: "CourseLesson_homeworkId_fkey")
}

model lessonattachment {
  id          Int          @id @default(autoincrement())
  lessonId    Int
  type        String       // pdf, word
  path        String       // file path in uploads
  originalName String
  createdAt   DateTime     @default(now())
  courselesson courselesson @relation(fields: [lessonId], references: [id], onDelete: Cascade, map: "LessonAttachment_lessonId_fkey")

  @@index([lessonId], map: "LessonAttachment_lessonId_fkey")
}

model exam {
  id            Int              @id @default(autoincrement())
  titleAr       String
  titleEn       String
  courseId      Int?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime
  lessons       courselesson[]
  questions     examquestion[]
  submissions   examsubmission[]
}

model examquestion {
  id            Int      @id @default(autoincrement())
  examId        Int
  order         Int      @default(0)
  type          String   // mcq, true_false, text, file
  questionTextAr String
  questionTextEn String
  options       String?  // JSON array for MCQ: ["A","B","C","D"]
  correctAnswer String?  // JSON: for mcq index, for true_false "true"/"false"
  points        Int      @default(1)
  createdAt     DateTime @default(now())
  exam          exam     @relation(fields: [examId], references: [id], onDelete: Cascade, map: "ExamQuestion_examId_fkey")
  answers       examsubmissionanswer[]

  @@index([examId], map: "ExamQuestion_examId_fkey")
}

model examsubmission {
  id          Int      @id @default(autoincrement())
  examId      Int
  userId      Int
  status      String   @default("submitted") // draft, submitted, graded
  totalScore  Int?
  maxScore    Int?
  gradedBy    Int?
  gradedAt    DateTime?
  feedback    String?
  submittedAt DateTime @default(now())
  exam        exam     @relation(fields: [examId], references: [id], onDelete: Cascade, map: "ExamSubmission_examId_fkey")
  user        user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "ExamSubmission_userId_fkey")
  answers     examsubmissionanswer[]

  @@index([examId], map: "ExamSubmission_examId_fkey")
  @@index([userId], map: "ExamSubmission_userId_fkey")
}

model examsubmissionanswer {
  id           Int             @id @default(autoincrement())
  submissionId Int
  questionId   Int
  textAnswer   String?
  filePath     String?
  selectedAnswer String?       // for mcq/true_false
  score        Int?
  feedback     String?
  examsubmission examsubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade, map: "ExamSubmissionAnswer_submissionId_fkey")
  examquestion  examquestion   @relation(fields: [questionId], references: [id], onDelete: Cascade, map: "ExamSubmissionAnswer_questionId_fkey")

  @@unique([submissionId, questionId], map: "ExamSubmissionAnswer_submissionId_questionId_key")
  @@index([submissionId], map: "ExamSubmissionAnswer_submissionId_fkey")
  @@index([questionId], map: "ExamSubmissionAnswer_questionId_fkey")
}

model homework {
  id          Int           @id @default(autoincrement())
  titleAr     String
  titleEn     String
  courseId    Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  lessons     courselesson[]
  questions   homeworkquestion[]
  submissions homeworksubmission[]
}

model homeworkquestion {
  id            Int      @id @default(autoincrement())
  homeworkId    Int
  order         Int      @default(0)
  type          String   // mcq, true_false, text, file
  questionTextAr String
  questionTextEn String
  options       String?  // JSON array for MCQ
  correctAnswer String?
  points        Int      @default(1)
  createdAt     DateTime @default(now())
  homework      homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade, map: "HomeworkQuestion_homeworkId_fkey")
  answers       homeworksubmissionanswer[]

  @@index([homeworkId], map: "HomeworkQuestion_homeworkId_fkey")
}

model homeworksubmission {
  id          Int      @id @default(autoincrement())
  homeworkId  Int
  userId      Int
  status      String   @default("submitted")
  totalScore  Int?
  maxScore    Int?
  gradedBy    Int?
  gradedAt    DateTime?
  feedback    String?
  submittedAt DateTime @default(now())
  homework    homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade, map: "HomeworkSubmission_homeworkId_fkey")
  user        user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "HomeworkSubmission_userId_fkey")
  answers     homeworksubmissionanswer[]

  @@index([homeworkId], map: "HomeworkSubmission_homeworkId_fkey")
  @@index([userId], map: "HomeworkSubmission_userId_fkey")
}

model homeworksubmissionanswer {
  id             Int                 @id @default(autoincrement())
  submissionId   Int
  questionId     Int
  textAnswer     String?
  filePath       String?
  selectedAnswer String?
  score          Int?
  feedback       String?
  homeworksubmission homeworksubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade, map: "HomeworkSubmissionAnswer_submissionId_fkey")
  homeworkquestion  homeworkquestion   @relation(fields: [questionId], references: [id], onDelete: Cascade, map: "HomeworkSubmissionAnswer_questionId_fkey")

  @@unique([submissionId, questionId], map: "HomeworkSubmissionAnswer_submissionId_questionId_key")
  @@index([submissionId], map: "HomeworkSubmissionAnswer_submissionId_fkey")
  @@index([questionId], map: "HomeworkSubmissionAnswer_questionId_fkey")
}

model coursesection {
  id           Int            @id @default(autoincrement())
  courseId     Int
  order        Int            @default(0)
  titleAr      String
  titleEn      String
  createdAt    DateTime       @default(now())
  courselesson courselesson[]
  course       course         @relation(fields: [courseId], references: [id], onDelete: Cascade, map: "CourseSection_courseId_fkey")

  @@index([courseId], map: "CourseSection_courseId_fkey")
}

model enrollment {
  id          Int               @id @default(autoincrement())
  userId      Int
  courseId    Int
  status      enrollment_status @default(ACTIVE)
  purchasedAt DateTime          @default(now())
  course      course            @relation(fields: [courseId], references: [id], onDelete: Cascade, map: "Enrollment_courseId_fkey")
  user        user              @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Enrollment_userId_fkey")
  payment     payment?

  @@unique([userId, courseId], map: "Enrollment_userId_courseId_key")
  @@index([courseId], map: "Enrollment_courseId_fkey")
}

model event {
  id          Int      @id @default(autoincrement())
  titleAr     String
  titleEn     String
  timeLabelAr String
  timeLabelEn String
  createdAt   DateTime @default(now())
}

model databankfolder {
  id        Int             @id @default(autoincrement())
  name      String
  parentId  Int?
  order     Int             @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  parent    databankfolder? @relation("DatabankFolderToFolder", fields: [parentId], references: [id], onDelete: Cascade, map: "DatabankFolder_parentId_fkey")
  children  databankfolder[] @relation("DatabankFolderToFolder")
  files     databankfile[]

  @@index([parentId], map: "DatabankFolder_parentId_fkey")
}

model databankfile {
  id           Int            @id @default(autoincrement())
  folderId     Int?
  path         String         // e.g. /uploads/cover-xxx.jpg or /uploads/lessons/pdf-xxx.pdf
  originalName String
  type         String         // pdf | word | image | video
  size         Int            @default(0) // bytes, for quota (100 GB total)
  createdAt    DateTime       @default(now())
  folder       databankfolder? @relation(fields: [folderId], references: [id], onDelete: SetNull, map: "DatabankFile_folderId_fkey")

  @@index([folderId], map: "DatabankFile_folderId_fkey")
}

model instructor {
  id            Int      @id @default(autoincrement())
  nameAr        String
  nameEn        String
  titleAr       String
  titleEn       String
  avatarUrl     String
  coursesCount  Int
  studentsCount Int
  rating        Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime
}

model notification {
  id        Int      @id @default(autoincrement())
  userId    Int?
  titleAr   String
  titleEn   String
  bodyAr    String?
  bodyEn    String?
  createdAt DateTime @default(now())
  user      user?    @relation(fields: [userId], references: [id], map: "Notification_userId_fkey")

  @@index([userId], map: "Notification_userId_fkey")
}

model chatconversation {
  id                  Int       @id @default(autoincrement())
  studentId           Int
  counterpartType     String    // "admin" | "teacher"
  counterpartAdminId  Int?
  counterpartUserId   Int?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  student             user      @relation(fields: [studentId], references: [id], onDelete: Cascade, map: "ChatConversation_studentId_fkey")
  counterpartAdmin    admin?    @relation(fields: [counterpartAdminId], references: [id], onDelete: Cascade, map: "ChatConversation_counterpartAdminId_fkey")
  counterpartUser     user?     @relation("ChatConversationTeacher", fields: [counterpartUserId], references: [id], onDelete: Cascade, map: "ChatConversation_counterpartUserId_fkey")
  messages            chatmessage[]

  @@index([studentId], map: "ChatConversation_studentId_fkey")
  @@index([counterpartAdminId], map: "ChatConversation_counterpartAdminId_fkey")
  @@index([counterpartUserId], map: "ChatConversation_counterpartUserId_fkey")
}

model chatmessage {
  id             Int                @id @default(autoincrement())
  conversationId Int
  senderType     String             // "student" | "admin" | "teacher"
  senderUserId   Int?
  senderAdminId Int?
  body           String
  createdAt      DateTime           @default(now())
  conversation   chatconversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade, map: "ChatMessage_conversationId_fkey")
  senderUser     user?              @relation(fields: [senderUserId], references: [id], onDelete: SetNull, map: "ChatMessage_senderUserId_fkey")
  senderAdmin    admin?             @relation(fields: [senderAdminId], references: [id], onDelete: SetNull, map: "ChatMessage_senderAdminId_fkey")

  @@index([conversationId], map: "ChatMessage_conversationId_fkey")
}

model payment {
  id              Int            @id @default(autoincrement())
  userId          Int
  courseId        Int
  amount          Int
  status          payment_status @default(pending)
  itemType        String         @default("course")
  itemId          Int?
  itemName        String?
  userName        String?
  userEmail       String?
  gateway         String?        // e.g. "cart", "stripe", "moyasar", "tamara"
  couponCode      String?
  discountAmount  Int?           @default(0) // amount discounted for this payment
  transactionId   String?        // external gateway reference
  enrollmentId    Int?           @unique
  createdAt       DateTime       @default(now())
  course          course         @relation(fields: [courseId], references: [id], onDelete: Cascade, map: "Payment_courseId_fkey")
  user            user           @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Payment_userId_fkey")
  enrollment      enrollment?    @relation(fields: [enrollmentId], references: [id], onDelete: SetNull, map: "Payment_enrollmentId_fkey")

  @@index([courseId], map: "Payment_courseId_fkey")
  @@index([userId], map: "Payment_userId_fkey")
  @@index([enrollmentId], map: "Payment_enrollmentId_fkey")
}

model teachersalarysettings {
  id                Int                                     @id @default(autoincrement())
  teacherId         Int                                     @unique(map: "TeacherSalarySettings_teacherId_key")
  workType          teachersalarysettings_workType          @default(both)
  calculationMethod teachersalarysettings_calculationMethod @default(fixed_per_session)
  fixedAmount       Int?
  percentage        Float?
  fixedBaseAmount   Int?
  percentageOnTop   Float?
  createdAt         DateTime                                @default(now())
  updatedAt         DateTime
}

model user {
  id           Int            @id @default(autoincrement())
  name         String
  email        String         @unique(map: "User_email_key")
  avatarUrl    String?
  passwordHash String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  bio          String?
  city         String?
  phone        String?
  role         user_role      @default(student)
  status       String         @default("active")
  titleAr      String?
  titleEn      String?
  category     String?
  country      String?
  parentNumber String?
  account            account[]
  attendance         attendance[]
  cartitem           cartitem[]
  course             course[]
  enrollment         enrollment[]
  chatConversationsAsStudent chatconversation[]
  chatConversationsAsTeacher chatconversation[] @relation("ChatConversationTeacher")
  chatMessages       chatmessage[]
  examsubmission     examsubmission[]
  homeworksubmission homeworksubmission[]
  livesession_created  livesession[]
  livesessionbooking  livesessionbooking[]
  notification       notification[]
  payment            payment[]
  wishlistitem       wishlistitem[]
}

model livesession {
  id               Int       @id @default(autoincrement())
  titleAr          String
  titleEn          String
  scheduledAt      DateTime  // date and time
  durationMinutes  Int       @default(60)
  maxSeats         Int       @default(50)
  provider         String    // "zoom" | "google_meet"
  meetingId        String?   // Zoom meeting id or Meet event id
  meetingUrl       String?   // join link for students
  meetingPassword  String?   // Zoom passcode if any
  courseId         Int?
  createdByUserId  Int?      // teacher (user)
  createdByAdminId Int?      // or admin
  noRecording      Boolean   @default(true) // session must not be recorded or shared
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  course           course?   @relation(fields: [courseId], references: [id], onDelete: SetNull, map: "LiveSession_courseId_fkey")
  createdBy        user?     @relation(fields: [createdByUserId], references: [id], onDelete: SetNull, map: "LiveSession_createdByUserId_fkey")
  createdByAdmin   admin?    @relation(fields: [createdByAdminId], references: [id], onDelete: SetNull, map: "LiveSession_createdByAdminId_fkey")
  bookings         livesessionbooking[]

  @@index([courseId], map: "LiveSession_courseId_fkey")
  @@index([createdByUserId], map: "LiveSession_createdByUserId_fkey")
  @@index([createdByAdminId], map: "LiveSession_createdByAdminId_fkey")
  @@index([scheduledAt], map: "LiveSession_scheduledAt_fkey")
}

model livesessionbooking {
  id        Int         @id @default(autoincrement())
  sessionId Int
  userId    Int
  createdAt DateTime    @default(now())
  session   livesession @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "LiveSessionBooking_sessionId_fkey")
  user      user        @relation(fields: [userId], references: [id], onDelete: Cascade, map: "LiveSessionBooking_userId_fkey")

  @@unique([sessionId, userId], map: "LiveSessionBooking_sessionId_userId_key")
  @@index([sessionId], map: "LiveSessionBooking_sessionId_fkey")
  @@index([userId], map: "LiveSessionBooking_userId_fkey")
}

model wishlistitem {
  id       Int      @id @default(autoincrement())
  userId   Int
  courseId Int
  addedAt  DateTime @default(now())
  course   course   @relation(fields: [courseId], references: [id], onDelete: Cascade, map: "WishlistItem_courseId_fkey")
  user     user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "WishlistItem_userId_fkey")

  @@unique([userId, courseId], map: "WishlistItem_userId_courseId_key")
  @@index([courseId], map: "WishlistItem_courseId_fkey")
}

enum coupon_discountType {
  percentage
  fixed
}

enum teachersalarysettings_workType {
  offline
  online
  both
}

enum enrollment_status {
  ACTIVE
  CANCELLED
  REFUNDED
}

enum teachersalarysettings_calculationMethod {
  fixed_per_session
  percentage
  fixed_plus_percentage
}

enum attendance_sessionType {
  offline
  online
}

enum payment_status {
  pending
  completed
  failed
  refunded
}

enum attendance_paymentStatus {
  paid
  partial
  unpaid
}

enum user_role {
  student
  instructor
  admin
  super_admin
}
