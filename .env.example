# Example environment configuration for the demolms project

# Connection string for the XAMPP MySQL database.
# Adjust user/host/port/dbname if your local setup differs.
# Add ?connection_limit=5 to reduce pool size and avoid "pool timeout" if needed.
DATABASE_URL="mysql://root@localhost:3306/lmsdb"

# Live sessions: create meetings via Zoom API (required for Zoom provider)
# Get from https://marketplace.zoom.us/ → Create JWT app
# ZOOM_API_KEY=your_zoom_api_key
# ZOOM_API_SECRET=your_zoom_api_secret

# Optional: Google Meet via Calendar API (JSON credentials from Google Cloud)
# GOOGLE_CALENDAR_CREDENTIALS={"type":"service_account",...}

# Real-time chat: run the socket server with: npm run dev:chat (in a separate terminal).
# If not running, chat works but messages do not update in real time.
# CHAT_SOCKET_URL=http://localhost:3001
# CHAT_SOCKET_PORT=3001
# NEXT_PUBLIC_CHAT_SOCKET_URL=http://localhost:3001

